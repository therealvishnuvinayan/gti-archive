generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  COLLABORATOR
}

enum CollaboratorType {
  INTERNAL
  EXTERNAL
}

enum ProjectCollaboratorParticipantType {
  GTI_INTERNAL_CLIENT
  GTI_SISTER_COMPANY_INTERNAL_CLIENT
  EXTERNAL_FREELANCER
  EXTERNAL_AGENCY
  EXTERNAL_VENDOR
  CLIENT_OF_GTI
}

enum CollaboratorAccess {
  FULL
  LIMITED
  NONE
}

enum ProjectStatus {
  ONGOING
  ON_HOLD
  PENDING
  COMPLETED
}

enum CalendarEventType {
  PROJECTS
  EVENTS
  REMINDERS
  PAYMENTS
}

enum CalendarEventTone {
  GREEN
  PURPLE
  BLUE
  AMBER
}

enum AttachmentAssetType {
  REVISION_ORIGINAL
  STAGE_SUBMISSION
  REVISION_PREVIEW
  REVISION_THUMBNAIL
  COMMENT_ATTACHMENT
  FINAL_ARCHIVE
  GENERAL_PROJECT_ASSET
}

enum AttachmentStatus {
  UPLOADING
  READY
  FAILED
  DELETED
}

enum ActivityLogAction {
  ASSET_UPLOADED
  COMMENT_ATTACHMENT_UPLOADED
  REVISION_CREATED
  FINAL_ARCHIVED
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  name              String?
  avatarUrl         String?
  department        String?
  phoneNumber       String?
  jobTitle          String?
  bio               String?
  passwordHash      String
  passwordChangedAt DateTime?
  role              UserRole           @default(COLLABORATOR)
  collaboratorType  CollaboratorType   @default(INTERNAL)
  projectAccess     CollaboratorAccess @default(NONE)
  calendarAccess    CollaboratorAccess @default(NONE)
  libraryAccess     CollaboratorAccess @default(NONE)
  archiveAccess     CollaboratorAccess @default(NONE)
  inviteToken       String?            @unique
  inviteExpiresAt   DateTime?
  inviteAcceptedAt  DateTime?
  sessions          Session[]
  projects          Project[]
  revisions         ProjectRevision[]
  comments          ProjectComment[]
  comparisonComments ComparisonComment[]
  attachments       ProjectAttachment[]
  activityLogs      ProjectActivityLog[]
  createdCollaboratorVisibilityPauses ProjectCollaboratorVisibilityPause[] @relation("ProjectCollaboratorVisibilityPauseCreator")
  assignedProjects  Project[]           @relation("ProjectExecutor")
  calendarEvents    CalendarEvent[]
  projectCollaborations       ProjectCollaborator[] @relation("ProjectCollaboratorUser")
  addedProjectCollaborations  ProjectCollaborator[] @relation("ProjectCollaboratorAdder")
  calendarCollaborations      CalendarCollaborator[] @relation("CalendarCollaboratorUser")
  addedCalendarCollaborations CalendarCollaborator[] @relation("CalendarCollaboratorAdder")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Project {
  id               String        @id @default(cuid())
  name             String
  category         String
  tag              String?
  executorName     String?
  executorUserId   String?
  executorUser     User?         @relation("ProjectExecutor", fields: [executorUserId], references: [id], onDelete: SetNull)
  description      String
  budget           Int
  currency         String        @default("USD")
  status           ProjectStatus @default(ONGOING)
  startDate        DateTime
  endDate          DateTime
  currentStageName String?
  stageCount       Int           @default(1)
  createdById      String
  createdBy        User          @relation(fields: [createdById], references: [id], onDelete: Restrict)
  stages           ProjectStage[]
  revisions        ProjectRevision[]
  comments         ProjectComment[]
  comparisonComments ComparisonComment[]
  attachments      ProjectAttachment[]
  activityLogs     ProjectActivityLog[]
  collaborators    ProjectCollaborator[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([createdById])
  @@index([executorUserId])
}

model ProjectCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  color       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProjectTag {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  color       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProjectCurrency {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name])
}

model ProjectCollaborator {
  projectId        String
  project          Project                           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId           String
  user             User                              @relation("ProjectCollaboratorUser", fields: [userId], references: [id], onDelete: Cascade)
  participantType  ProjectCollaboratorParticipantType?
  chatVisibilityPaused Boolean                       @default(false)
  addedById        String?
  addedBy          User?                             @relation("ProjectCollaboratorAdder", fields: [addedById], references: [id], onDelete: SetNull)
  visibilityPauses ProjectCollaboratorVisibilityPause[]
  createdAt        DateTime                          @default(now())

  @@id([projectId, userId])
  @@index([userId])
  @@index([addedById])
}

model ProjectCollaboratorVisibilityPause {
  id          String              @id @default(cuid())
  projectId   String
  userId      String
  collaborator ProjectCollaborator @relation(fields: [projectId, userId], references: [projectId, userId], onDelete: Cascade)
  pausedAt    DateTime
  resumedAt   DateTime?
  createdById String
  createdBy   User                @relation("ProjectCollaboratorVisibilityPauseCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([projectId, userId, pausedAt])
  @@index([projectId, pausedAt, resumedAt])
  @@index([createdById])
}

model CalendarCollaborator {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation("CalendarCollaboratorUser", fields: [userId], references: [id], onDelete: Cascade)
  addedById String?
  addedBy   User?    @relation("CalendarCollaboratorAdder", fields: [addedById], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([addedById])
}

model ProjectStage {
  id        String        @id @default(cuid())
  projectId String
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  description String?
  budget    Int?
  plannedStartAt DateTime?
  plannedDueAt DateTime?
  status    ProjectStatus @default(PENDING)
  order     Int
  revisions ProjectRevision[]
  comments  ProjectComment[]
  comparisonComments ComparisonComment[]
  attachments ProjectAttachment[]
  activityLogs ProjectActivityLog[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([projectId, order])
}

model ProjectRevision {
  id             String               @id @default(cuid())
  projectId      String
  project        Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stageId        String
  stage          ProjectStage         @relation(fields: [stageId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User                 @relation(fields: [createdById], references: [id], onDelete: Restrict)
  revisionNumber Int
  title          String
  summary        String?
  attachments    ProjectAttachment[]
  comments       ProjectComment[]
  activityLogs   ProjectActivityLog[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([stageId, revisionNumber])
  @@index([projectId, stageId, createdAt])
  @@index([createdById])
}

model ProjectComment {
  id           String               @id @default(cuid())
  projectId    String
  project      Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stageId      String
  stage        ProjectStage         @relation(fields: [stageId], references: [id], onDelete: Cascade)
  revisionId   String?
  revision     ProjectRevision?     @relation(fields: [revisionId], references: [id], onDelete: SetNull)
  authorId     String
  author       User                 @relation(fields: [authorId], references: [id], onDelete: Restrict)
  body         String
  attachments  ProjectAttachment[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([projectId, stageId, createdAt])
  @@index([revisionId])
  @@index([authorId])
}

model ProjectAttachment {
  id               String             @id @default(cuid())
  projectId        String
  project          Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stageId          String?
  stage            ProjectStage?      @relation(fields: [stageId], references: [id], onDelete: Cascade)
  revisionId       String?
  revision         ProjectRevision?   @relation(fields: [revisionId], references: [id], onDelete: SetNull)
  commentId        String?
  comment          ProjectComment?    @relation(fields: [commentId], references: [id], onDelete: SetNull)
  uploadedById     String
  uploadedBy       User               @relation(fields: [uploadedById], references: [id], onDelete: Restrict)
  baseComparisonComments ComparisonComment[] @relation("ComparisonCommentBaseAttachment")
  compareComparisonComments ComparisonComment[] @relation("ComparisonCommentCompareAttachment")
  fileName         String
  originalFileName String
  mimeType         String
  fileSize         Int
  bucket           String
  storageKey       String             @unique
  assetType        AttachmentAssetType
  status           AttachmentStatus   @default(UPLOADING)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([projectId, createdAt])
  @@index([stageId, createdAt])
  @@index([revisionId, createdAt])
  @@index([commentId, createdAt])
  @@index([uploadedById])
  @@index([status])
}

model ComparisonComment {
  id                String            @id @default(cuid())
  projectId         String
  project           Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stageId           String
  stage             ProjectStage      @relation(fields: [stageId], references: [id], onDelete: Cascade)
  baseAttachmentId  String
  baseAttachment    ProjectAttachment @relation("ComparisonCommentBaseAttachment", fields: [baseAttachmentId], references: [id], onDelete: Cascade)
  compareAttachmentId String
  compareAttachment ProjectAttachment @relation("ComparisonCommentCompareAttachment", fields: [compareAttachmentId], references: [id], onDelete: Cascade)
  xPercent          Float
  yPercent          Float
  body              String
  createdById       String
  createdBy         User              @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([projectId, stageId, createdAt])
  @@index([baseAttachmentId, compareAttachmentId, createdAt])
  @@index([createdById])
}

model ProjectActivityLog {
  id         String            @id @default(cuid())
  projectId  String
  project    Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stageId    String?
  stage      ProjectStage?     @relation(fields: [stageId], references: [id], onDelete: Cascade)
  revisionId String?
  revision   ProjectRevision?  @relation(fields: [revisionId], references: [id], onDelete: SetNull)
  actorId    String
  actor      User              @relation(fields: [actorId], references: [id], onDelete: Restrict)
  action     ActivityLogAction
  metadata   Json?
  createdAt  DateTime          @default(now())

  @@index([projectId, createdAt])
  @@index([stageId, createdAt])
  @@index([revisionId, createdAt])
  @@index([actorId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model CalendarEvent {
  id          String            @id @default(cuid())
  title       String
  details     String?
  startAt     DateTime
  endAt       DateTime
  type        CalendarEventType
  tone        CalendarEventTone
  createdById String
  createdBy   User              @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([startAt])
  @@index([endAt])
  @@index([createdById])
}
