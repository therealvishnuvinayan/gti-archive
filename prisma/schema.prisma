generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  COLLABORATOR
}

enum CollaboratorType {
  INTERNAL
  EXTERNAL
}

enum CollaboratorAccess {
  FULL
  LIMITED
  NONE
}

enum ProjectStatus {
  ONGOING
  ON_HOLD
  PENDING
  COMPLETED
}

enum CurrencyCode {
  USD
  AED
  EUR
  GBP
  INR
}

enum CalendarEventType {
  PROJECTS
  EVENTS
  REMINDERS
  PAYMENTS
}

enum CalendarEventTone {
  GREEN
  PURPLE
  BLUE
  AMBER
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  name              String?
  passwordHash      String
  role              UserRole           @default(COLLABORATOR)
  collaboratorType  CollaboratorType   @default(INTERNAL)
  projectAccess     CollaboratorAccess @default(NONE)
  calendarAccess    CollaboratorAccess @default(NONE)
  libraryAccess     CollaboratorAccess @default(NONE)
  archiveAccess     CollaboratorAccess @default(NONE)
  inviteToken       String?            @unique
  inviteExpiresAt   DateTime?
  inviteAcceptedAt  DateTime?
  sessions          Session[]
  projects          Project[]
  calendarEvents CalendarEvent[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Project {
  id               String        @id @default(cuid())
  name             String
  category         String
  tag              String?
  description      String
  budget           Int
  currency         CurrencyCode  @default(USD)
  status           ProjectStatus @default(ONGOING)
  startDate        DateTime
  endDate          DateTime
  currentStageName String?
  stageCount       Int           @default(1)
  createdById      String
  createdBy        User          @relation(fields: [createdById], references: [id], onDelete: Restrict)
  stages           ProjectStage[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([createdById])
}

model ProjectStage {
  id        String        @id @default(cuid())
  projectId String
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  description String?
  budget    Int?
  status    ProjectStatus @default(PENDING)
  order     Int
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([projectId, order])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model CalendarEvent {
  id          String            @id @default(cuid())
  title       String
  details     String?
  startAt     DateTime
  endAt       DateTime
  type        CalendarEventType
  tone        CalendarEventTone
  createdById String
  createdBy   User              @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([startAt])
  @@index([endAt])
  @@index([createdById])
}
