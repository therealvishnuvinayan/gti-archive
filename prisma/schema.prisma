generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  COLLABORATOR
}

enum CollaboratorType {
  GTI_INTERNAL_CLIENT
  GTI_SISTER_COMPANY_INTERNAL_CLIENT
  EXTERNAL_FREELANCER
  EXTERNAL_AGENCY
  EXTERNAL_VENDOR
  CLIENT_OF_GTI
}

enum ProjectCollaboratorParticipantType {
  GTI_INTERNAL_CLIENT
  GTI_SISTER_COMPANY_INTERNAL_CLIENT
  EXTERNAL_FREELANCER
  EXTERNAL_AGENCY
  EXTERNAL_VENDOR
  CLIENT_OF_GTI
}

enum StageStatus {
  PENDING
  ONGOING
  ON_HOLD
  COMPLETED
}

enum ProjectExecutionType {
  INTERNAL
  EXTERNAL
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ProjectExecutorRole {
  MAIN_EXECUTOR
  EXECUTOR
}

enum CalendarEventType {
  PROJECTS
  EVENTS
  REMINDERS
  PAYMENTS
}

enum CalendarEventTone {
  GREEN
  PURPLE
  BLUE
  AMBER
}

enum AttachmentAssetType {
  REVISION_ORIGINAL
  STAGE_SUBMISSION
  REVISION_PREVIEW
  REVISION_THUMBNAIL
  COMMENT_ATTACHMENT
  STAGE_INVOICE
  FINAL_ARCHIVE
  GENERAL_PROJECT_ASSET
}

enum AttachmentStatus {
  UPLOADING
  READY
  FAILED
  DELETED
}

enum SubmissionReviewStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum ProjectRevisionStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum ActivityLogAction {
  ASSET_UPLOADED
  COMMENT_ATTACHMENT_UPLOADED
  REVISION_CREATED
  FINAL_ARCHIVED
}

enum ArchiveRecordStatus {
  COMPLETED
  ARCHIVED
}

enum ProjectCompletionStepStatus {
  NOT_STARTED
  NOT_REQUIRED
  PENDING
  COMPLETED
}

enum ProjectCompletionDocumentType {
  AUTHORITY_APPROVAL_PROOF
  COPYRIGHT_TRANSFER
  INVOICE
}

enum NotificationType {
  PROJECT_ASSIGNED
  PROJECT_CREATED
  PROJECT_UPDATED
  COLLABORATOR_ADDED
  COLLABORATOR_REMOVED
  BRIEF_ACCEPTED
  REVISION_SUBMITTED
  REVISION_APPROVED
  REVISION_REJECTED
  SUBMISSION_PENDING_REVIEW
  SUBMISSION_COMPLETED
  SUBMISSION_REVISION_REQUESTED
  STAGE_COMPLETED
  NEXT_STAGE_ACTIVATED
  COMMENT_ADDED
  MENTION
  FILE_UPLOADED
  PROJECT_ARCHIVED
  APPROVAL_REQUIRED
  APPROVAL_PROOF_UPLOADED
  COPYRIGHT_TRANSFER_REQUIRED
  COPYRIGHT_DOCUMENT_UPLOADED
  INVOICE_REQUESTED
  INVOICE_UPLOADED
}

enum NotificationEntityType {
  PROJECT
  STAGE
  REVISION
  COMMENT
  ATTACHMENT
  ARCHIVE
  COMPLETION_WORKFLOW
  COMPLETION_DOCUMENT
}

model User {
  id                                  String                               @id @default(cuid())
  email                               String                               @unique
  name                                String?
  avatarUrl                           String?
  department                          String?
  phoneNumber                         String?
  jobTitle                            String?
  bio                                 String?
  passwordHash                        String
  passwordChangedAt                   DateTime?
  role                                UserRole                             @default(COLLABORATOR)
  collaboratorType                    CollaboratorType                     @default(GTI_INTERNAL_CLIENT)
  inviteToken                         String?                              @unique
  inviteExpiresAt                     DateTime?
  inviteAcceptedAt                    DateTime?
  sessions                            Session[]
  passwordResetTokens                 PasswordResetToken[]
  projects                            Project[]
  revisions                           ProjectRevision[]
  reviewedRevisions                   ProjectRevision[]                    @relation("ProjectRevisionReviewer")
  comments                            ProjectComment[]
  deletedProjectComments              ProjectComment[]                     @relation("ProjectCommentDeletedBy")
  commentMentions                     ProjectCommentMention[]
  comparisonComments                  ComparisonComment[]
  attachments                         ProjectAttachment[]
  projectArchives                     ProjectArchive[]                     @relation("ProjectArchiveArchivedBy")
  archivedProjectFiles                ArchivedProjectFile[]                @relation("ArchivedProjectFileArchivedBy")
  approvalContactWorkflows            ProjectCompletionWorkflow[]          @relation("ProjectCompletionApprovalContact")
  copyrightContactWorkflows           ProjectCompletionWorkflow[]          @relation("ProjectCompletionCopyrightContact")
  uploadedCompletionDocuments         ProjectCompletionDocument[]          @relation("ProjectCompletionDocumentUploadedBy")
  manualArchiveFiles                  ManualArchiveFile[]                  @relation("ManualArchiveFileUploadedBy")
  manualLibraryAssets                 ManualLibraryAsset[]                 @relation("ManualLibraryAssetUploadedBy")
  notifications                       Notification[]
  fileFavorites                       FileFavorite[]
  manualLibraryAssetFavorites         ManualLibraryAssetFavorite[]
  activityLogs                        ProjectActivityLog[]
  createdCollaboratorVisibilityPauses ProjectCollaboratorVisibilityPause[] @relation("ProjectCollaboratorVisibilityPauseCreator")
  projectExecutorAssignments          ProjectExecutor[]                    @relation("ProjectExecutorUser")
  addedProjectExecutorAssignments     ProjectExecutor[]                    @relation("ProjectExecutorAddedBy")
  startedProjectStages                ProjectStage[]                       @relation("ProjectStageStarter")
  reviewedStageSubmissions            ProjectAttachment[]                  @relation("SubmissionReviewer")
  stageInvoiceRequestsMade            StageInvoiceRequest[]                @relation("StageInvoiceRequestRequester")
  stageInvoiceRequestsReceived        StageInvoiceRequest[]                @relation("StageInvoiceRequestRecipient")
  calendarEvents                      CalendarEvent[]
  projectCollaborations               ProjectCollaborator[]                @relation("ProjectCollaboratorUser")
  addedProjectCollaborations          ProjectCollaborator[]                @relation("ProjectCollaboratorAdder")
  calendarCollaborations              CalendarCollaborator[]               @relation("CalendarCollaboratorUser")
  addedCalendarCollaborations         CalendarCollaborator[]               @relation("CalendarCollaboratorAdder")
  createdAt                           DateTime                             @default(now())
  updatedAt                           DateTime                             @updatedAt
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model PermissionDefinition {
  id                          String                       @id @default(cuid())
  key                         String                       @unique
  label                       String
  description                 String
  group                       String
  isSystem                    Boolean                      @default(true)
  rolePermissions             RolePermission[]
  collaboratorTypePermissions CollaboratorTypePermission[]
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
}

model RolePermission {
  id            String               @id @default(cuid())
  role          UserRole
  permissionKey String
  permission    PermissionDefinition @relation(fields: [permissionKey], references: [key], onDelete: Restrict)
  enabled       Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@unique([role, permissionKey])
  @@index([role])
  @@index([permissionKey])
}

model CollaboratorTypePermission {
  id               String               @id @default(cuid())
  collaboratorType CollaboratorType
  permissionKey    String
  permission       PermissionDefinition @relation(fields: [permissionKey], references: [key], onDelete: Restrict)
  enabled          Boolean              @default(true)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@unique([collaboratorType, permissionKey])
  @@index([collaboratorType])
  @@index([permissionKey])
}

model Project {
  id                  String                      @id @default(cuid())
  name                String
  category            String
  description         String
  executionType       ProjectExecutionType        @default(EXTERNAL)
  budgetRequired      Boolean                     @default(false)
  budget              Int?
  currency            String                      @default("USD")
  statusId            String?
  status              ProjectStatusOption?        @relation(fields: [statusId], references: [id], onDelete: SetNull)
  priority            ProjectPriority             @default(MEDIUM)
  startDate           DateTime
  endDate             DateTime
  currentStageName    String?
  stageCount          Int                         @default(1)
  createdById         String
  createdBy           User                        @relation(fields: [createdById], references: [id], onDelete: Restrict)
  isPinned            Boolean                     @default(false)
  stages              ProjectStage[]
  tags                ProjectTagAssignment[]
  revisions           ProjectRevision[]
  comments            ProjectComment[]
  comparisonComments  ComparisonComment[]
  attachments         ProjectAttachment[]
  invoiceRequests     StageInvoiceRequest[]
  activityLogs        ProjectActivityLog[]
  collaborators       ProjectCollaborator[]
  executors           ProjectExecutor[]
  archive             ProjectArchive?
  archivedFiles       ArchivedProjectFile[]
  completionWorkflow  ProjectCompletionWorkflow?
  completionDocuments ProjectCompletionDocument[]
  completedAt         DateTime?
  archivedAt          DateTime?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt

  @@index([statusId])
  @@index([isPinned])
  @@index([createdAt])
  @@index([createdById])
}

model ProjectCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  color       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProjectStatusOption {
  id          String             @id @default(cuid())
  name        String
  slug        String             @unique
  description String?
  color       String?
  groupId     String?
  group       ProjectStatusGroupOption? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  sortOrder   Int                @default(0)
  isActive    Boolean            @default(true)
  isSystem    Boolean            @default(false)
  projects    Project[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([slug])
  @@index([groupId, isActive, sortOrder])
}

model ProjectStatusGroupOption {
  id          String                @id @default(cuid())
  name        String
  slug        String                @unique
  description String?
  color       String?
  sortOrder   Int                   @default(0)
  isActive    Boolean               @default(true)
  isSystem    Boolean               @default(false)
  statuses    ProjectStatusOption[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([slug])
  @@index([isActive, sortOrder])
}

model ProjectTag {
  id          String                 @id @default(cuid())
  name        String                 @unique
  description String?
  color       String?
  isActive    Boolean                @default(true)
  projects    ProjectTagAssignment[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
}

model ProjectTagAssignment {
  projectId String
  tagId     String
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag       ProjectTag @relation(fields: [tagId], references: [id], onDelete: Restrict)
  createdAt DateTime   @default(now())

  @@id([projectId, tagId])
  @@index([tagId])
}

model AssetTag {
  id                  String                                @id @default(cuid())
  name                String                                @unique
  description         String?
  color               String?
  isActive            Boolean                               @default(true)
  projectAttachments  ProjectAttachmentAssetTagAssignment[]
  manualArchiveFiles  ManualArchiveFileAssetTagAssignment[]
  manualLibraryAssets ManualLibraryAssetTagAssignment[]
  createdAt           DateTime                              @default(now())
  updatedAt           DateTime                              @updatedAt
}

model ArchiveCategory {
  id                 String              @id @default(cuid())
  name               String
  slug               String              @unique
  description        String?
  iconUrl            String?
  iconKey            String?
  color              String?
  parentId           String?
  parent             ArchiveCategory?    @relation("ArchiveCategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children           ArchiveCategory[]   @relation("ArchiveCategoryHierarchy")
  sortOrder          Int                 @default(0)
  isActive           Boolean             @default(true)
  isSystem           Boolean             @default(false)
  projectArchives    ProjectArchive[]
  manualArchiveFiles ManualArchiveFile[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([slug])
  @@index([parentId])
  @@index([isActive, sortOrder])
}

model ProjectAttachmentAssetTagAssignment {
  attachmentId String
  tagId        String
  attachment   ProjectAttachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  tag          AssetTag          @relation(fields: [tagId], references: [id], onDelete: Restrict)
  createdAt    DateTime          @default(now())

  @@id([attachmentId, tagId])
  @@index([tagId])
}

model ManualArchiveFileAssetTagAssignment {
  archiveFileId String
  tagId         String
  archiveFile   ManualArchiveFile @relation(fields: [archiveFileId], references: [id], onDelete: Cascade)
  tag           AssetTag          @relation(fields: [tagId], references: [id], onDelete: Restrict)
  createdAt     DateTime          @default(now())

  @@id([archiveFileId, tagId])
  @@index([tagId])
}

model ManualLibraryAssetTagAssignment {
  assetId   String
  tagId     String
  asset     ManualLibraryAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  tag       AssetTag           @relation(fields: [tagId], references: [id], onDelete: Restrict)
  createdAt DateTime           @default(now())

  @@id([assetId, tagId])
  @@index([tagId])
}

model ProjectCollaborator {
  projectId            String
  project              Project                              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId               String
  user                 User                                 @relation("ProjectCollaboratorUser", fields: [userId], references: [id], onDelete: Cascade)
  participantType      ProjectCollaboratorParticipantType?
  chatVisibilityPaused Boolean                              @default(false)
  addedById            String?
  addedBy              User?                                @relation("ProjectCollaboratorAdder", fields: [addedById], references: [id], onDelete: SetNull)
  visibilityPauses     ProjectCollaboratorVisibilityPause[]
  createdAt            DateTime                             @default(now())

  @@id([projectId, userId])
  @@index([userId])
  @@index([addedById])
}

model ProjectExecutor {
  projectId String
  project   Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User                @relation("ProjectExecutorUser", fields: [userId], references: [id], onDelete: Cascade)
  role      ProjectExecutorRole @default(EXECUTOR)
  addedById String?
  addedBy   User?               @relation("ProjectExecutorAddedBy", fields: [addedById], references: [id], onDelete: SetNull)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@id([projectId, userId])
  @@index([userId])
  @@index([addedById])
  @@index([role])
}

model ProjectCollaboratorVisibilityPause {
  id           String              @id @default(cuid())
  projectId    String
  userId       String
  collaborator ProjectCollaborator @relation(fields: [projectId, userId], references: [projectId, userId], onDelete: Cascade)
  pausedAt     DateTime
  resumedAt    DateTime?
  createdById  String
  createdBy    User                @relation("ProjectCollaboratorVisibilityPauseCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([projectId, userId, pausedAt])
  @@index([projectId, pausedAt, resumedAt])
  @@index([createdById])
}

model CalendarCollaborator {
  id        String             @id @default(cuid())
  userId    String             @unique
  user      User               @relation("CalendarCollaboratorUser", fields: [userId], references: [id], onDelete: Cascade)
  addedById String?
  addedBy   User?              @relation("CalendarCollaboratorAdder", fields: [addedById], references: [id], onDelete: SetNull)
  createdAt DateTime           @default(now())

  @@index([addedById])
}

model ProjectStage {
  id                 String                @id @default(cuid())
  projectId          String
  project            Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name               String
  description        String?
  budget             Int?
  plannedStartAt     DateTime?
  plannedDueAt       DateTime?
  invoiceRequired    Boolean               @default(true)
  actualStartedAt    DateTime?
  startedById        String?
  startedBy          User?                 @relation("ProjectStageStarter", fields: [startedById], references: [id], onDelete: SetNull)
  status             StageStatus           @default(PENDING)
  order              Int
  revisions          ProjectRevision[]
  comments           ProjectComment[]
  comparisonComments ComparisonComment[]
  attachments        ProjectAttachment[]
  invoiceRequests    StageInvoiceRequest[]
  archives           ProjectArchive[]      @relation("ProjectArchiveFinalStage")
  activityLogs       ProjectActivityLog[]
  completedAt        DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([projectId, order])
  @@index([startedById])
}

model ProjectRevision {
  id              String                @id @default(cuid())
  projectId       String
  project         Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stageId         String
  stage           ProjectStage          @relation(fields: [stageId], references: [id], onDelete: Cascade)
  createdById     String
  createdBy       User                  @relation(fields: [createdById], references: [id], onDelete: Restrict)
  reviewedById    String?
  reviewedBy      User?                 @relation("ProjectRevisionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  revisionNumber  Int
  title           String
  summary         String?
  status          ProjectRevisionStatus @default(PENDING_REVIEW)
  reviewedAt      DateTime?
  rejectionReason String?
  attachments     ProjectAttachment[]
  archivedFiles   ArchivedProjectFile[] @relation("ArchivedProjectFileSourceRevision")
  comments        ProjectComment[]
  activityLogs    ProjectActivityLog[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([stageId, revisionNumber])
  @@index([projectId, stageId, createdAt])
  @@index([createdById])
  @@index([reviewedById])
  @@index([status])
}

model ProjectComment {
  id              String                  @id @default(cuid())
  projectId       String
  project         Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stageId         String
  stage           ProjectStage            @relation(fields: [stageId], references: [id], onDelete: Cascade)
  revisionId      String?
  revision        ProjectRevision?        @relation(fields: [revisionId], references: [id], onDelete: SetNull)
  authorId        String
  author          User                    @relation(fields: [authorId], references: [id], onDelete: Restrict)
  body            String
  deletedAt       DateTime?
  deletedByUserId String?
  deletedByUser   User?                   @relation("ProjectCommentDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  attachments     ProjectAttachment[]
  mentions        ProjectCommentMention[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([projectId, stageId, createdAt])
  @@index([revisionId])
  @@index([authorId])
  @@index([deletedByUserId])
}

model ProjectCommentMention {
  id              String         @id @default(cuid())
  commentId       String
  comment         ProjectComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  mentionedUserId String
  mentionedUser   User           @relation(fields: [mentionedUserId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())

  @@unique([commentId, mentionedUserId])
  @@index([mentionedUserId, createdAt])
  @@index([commentId, createdAt])
}

model ProjectAttachment {
  id                        String                                @id @default(cuid())
  projectId                 String
  project                   Project                               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stageId                   String?
  stage                     ProjectStage?                         @relation(fields: [stageId], references: [id], onDelete: Cascade)
  revisionId                String?
  revision                  ProjectRevision?                      @relation(fields: [revisionId], references: [id], onDelete: SetNull)
  commentId                 String?
  comment                   ProjectComment?                       @relation(fields: [commentId], references: [id], onDelete: SetNull)
  uploadedById              String
  uploadedBy                User                                  @relation(fields: [uploadedById], references: [id], onDelete: Restrict)
  reviewedById              String?
  reviewedBy                User?                                 @relation("SubmissionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  baseComparisonComments    ComparisonComment[]                   @relation("ComparisonCommentBaseAttachment")
  compareComparisonComments ComparisonComment[]                   @relation("ComparisonCommentCompareAttachment")
  fileFavorites             FileFavorite[]
  fileName                  String
  originalFileName          String
  mimeType                  String
  fileSize                  Int
  bucket                    String
  storageKey                String                                @unique
  assetType                 AttachmentAssetType
  status                    AttachmentStatus                      @default(UPLOADING)
  submissionReviewStatus    SubmissionReviewStatus?
  reviewedAt                DateTime?
  reviewNote                String?
  archivedFiles             ArchivedProjectFile[]                 @relation("ArchivedProjectFileSourceAttachment")
  assetTags                 ProjectAttachmentAssetTagAssignment[]
  createdAt                 DateTime                              @default(now())
  updatedAt                 DateTime                              @updatedAt

  @@index([projectId, createdAt])
  @@index([stageId, createdAt])
  @@index([revisionId, createdAt])
  @@index([commentId, createdAt])
  @@index([uploadedById])
  @@index([reviewedById])
  @@index([status])
  @@index([submissionReviewStatus])
}

model StageInvoiceRequest {
  id              String       @id @default(cuid())
  projectId       String
  project         Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stageId         String
  stage           ProjectStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  requestedById   String
  requestedBy     User         @relation("StageInvoiceRequestRequester", fields: [requestedById], references: [id], onDelete: Restrict)
  requestedFromId String
  requestedFrom   User         @relation("StageInvoiceRequestRecipient", fields: [requestedFromId], references: [id], onDelete: Restrict)
  note            String?
  fulfilledAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([stageId])
  @@index([projectId, createdAt])
  @@index([requestedById])
  @@index([requestedFromId])
  @@index([fulfilledAt])
}

model FileFavorite {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachmentId String
  attachment   ProjectAttachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  createdAt    DateTime          @default(now())

  @@unique([userId, attachmentId])
  @@index([userId])
  @@index([attachmentId])
  @@index([userId, createdAt])
}

model ManualLibraryAssetFavorite {
  id                 String            @id @default(cuid())
  userId             String
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  manualLibraryAssetId String
  manualLibraryAsset ManualLibraryAsset @relation(fields: [manualLibraryAssetId], references: [id], onDelete: Cascade)
  createdAt          DateTime          @default(now())

  @@unique([userId, manualLibraryAssetId])
  @@index([userId])
  @@index([manualLibraryAssetId])
  @@index([userId, createdAt])
}

model ComparisonComment {
  id                  String            @id @default(cuid())
  projectId           String
  project             Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stageId             String
  stage               ProjectStage      @relation(fields: [stageId], references: [id], onDelete: Cascade)
  baseAttachmentId    String
  baseAttachment      ProjectAttachment @relation("ComparisonCommentBaseAttachment", fields: [baseAttachmentId], references: [id], onDelete: Cascade)
  compareAttachmentId String
  compareAttachment   ProjectAttachment @relation("ComparisonCommentCompareAttachment", fields: [compareAttachmentId], references: [id], onDelete: Cascade)
  xPercent            Float
  yPercent            Float
  body                String
  createdById         String
  createdBy           User              @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([projectId, stageId, createdAt])
  @@index([baseAttachmentId, compareAttachmentId, createdAt])
  @@index([createdById])
}

model ProjectActivityLog {
  id         String            @id @default(cuid())
  projectId  String
  project    Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stageId    String?
  stage      ProjectStage?     @relation(fields: [stageId], references: [id], onDelete: Cascade)
  revisionId String?
  revision   ProjectRevision?  @relation(fields: [revisionId], references: [id], onDelete: SetNull)
  actorId    String
  actor      User              @relation(fields: [actorId], references: [id], onDelete: Restrict)
  action     ActivityLogAction
  metadata   Json?
  createdAt  DateTime          @default(now())

  @@index([projectId, createdAt])
  @@index([stageId, createdAt])
  @@index([revisionId, createdAt])
  @@index([actorId])
}

model ProjectArchive {
  id                String                @id @default(cuid())
  projectId         String                @unique
  project           Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  finalStageId      String
  finalStage        ProjectStage          @relation("ProjectArchiveFinalStage", fields: [finalStageId], references: [id], onDelete: Restrict)
  archivedById      String
  archivedBy        User                  @relation("ProjectArchiveArchivedBy", fields: [archivedById], references: [id], onDelete: Restrict)
  projectName       String
  projectCategory   String
  projectTag        String?
  archiveCategoryId String?
  archiveCategory   ArchiveCategory?      @relation(fields: [archiveCategoryId], references: [id], onDelete: SetNull)
  status            ArchiveRecordStatus   @default(ARCHIVED)
  archivedAt        DateTime
  files             ArchivedProjectFile[]
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([archiveCategoryId, archivedAt])
  @@index([archivedById])
}

model ArchivedProjectFile {
  id                   String            @id @default(cuid())
  archiveId            String
  archive              ProjectArchive    @relation(fields: [archiveId], references: [id], onDelete: Cascade)
  projectId            String
  project              Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceAttachmentId   String
  sourceAttachment     ProjectAttachment @relation("ArchivedProjectFileSourceAttachment", fields: [sourceAttachmentId], references: [id], onDelete: Restrict)
  sourceRevisionId     String?
  sourceRevision       ProjectRevision?  @relation("ArchivedProjectFileSourceRevision", fields: [sourceRevisionId], references: [id], onDelete: SetNull)
  finalArchiveFileName String
  originalFileName     String
  mimeType             String
  fileSize             Int
  bucket               String
  storageKey           String
  archivedById         String
  archivedBy           User              @relation("ArchivedProjectFileArchivedBy", fields: [archivedById], references: [id], onDelete: Restrict)
  archivedAt           DateTime
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@unique([archiveId, finalArchiveFileName])
  @@unique([archiveId, sourceAttachmentId])
  @@index([projectId, archivedAt])
  @@index([sourceAttachmentId])
  @@index([sourceRevisionId])
  @@index([archivedById])
}

model ProjectCompletionWorkflow {
  id                              String                      @id @default(cuid())
  projectId                       String                      @unique
  project                         Project                     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  approvalRequired                Boolean?
  approvalStatus                  ProjectCompletionStepStatus @default(NOT_STARTED)
  approvalContactUserId           String?
  approvalContactUser             User?                       @relation("ProjectCompletionApprovalContact", fields: [approvalContactUserId], references: [id], onDelete: SetNull)
  approvalNote                    String?
  approvalSelectedArchivedFileIds String[]                    @default([])
  approvalRequestedAt             DateTime?
  approvalCompletedAt             DateTime?
  copyrightRequired               Boolean?
  copyrightStatus                 ProjectCompletionStepStatus @default(NOT_STARTED)
  copyrightContactUserId          String?
  copyrightContactUser            User?                       @relation("ProjectCompletionCopyrightContact", fields: [copyrightContactUserId], references: [id], onDelete: SetNull)
  copyrightNote                   String?
  copyrightRequestedAt            DateTime?
  copyrightCompletedAt            DateTime?
  invoiceStatus                   ProjectCompletionStepStatus @default(NOT_STARTED)
  invoiceCompletedAt              DateTime?
  completedAt                     DateTime?
  documents                       ProjectCompletionDocument[]
  createdAt                       DateTime                    @default(now())
  updatedAt                       DateTime                    @updatedAt

  @@index([approvalStatus])
  @@index([copyrightStatus])
  @@index([invoiceStatus])
  @@index([approvalContactUserId])
  @@index([copyrightContactUserId])
}

model ProjectCompletionDocument {
  id               String                        @id @default(cuid())
  projectId        String
  project          Project                       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workflowId       String
  workflow         ProjectCompletionWorkflow     @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  type             ProjectCompletionDocumentType
  originalFileName String
  archiveFileName  String
  mimeType         String
  fileSize         Int
  bucket           String
  storageKey       String                        @unique
  uploadedById     String
  uploadedBy       User                          @relation("ProjectCompletionDocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)
  uploadedAt       DateTime
  createdAt        DateTime                      @default(now())
  updatedAt        DateTime                      @updatedAt

  @@unique([workflowId, type])
  @@index([projectId, type, uploadedAt])
  @@index([uploadedById])
}

model ManualArchiveFile {
  id                String                                @id @default(cuid())
  fileName          String
  originalFileName  String
  projectName       String?
  projectCreatedBy  String?
  archiveCategoryId String?
  archiveCategory   ArchiveCategory?                      @relation(fields: [archiveCategoryId], references: [id], onDelete: SetNull)
  projectDate       DateTime?
  mimeType          String
  fileSize          Int
  bucket            String
  storageKey        String                                @unique
  status            AttachmentStatus                      @default(UPLOADING)
  uploadedById      String
  uploadedBy        User                                  @relation("ManualArchiveFileUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)
  assetTags         ManualArchiveFileAssetTagAssignment[]
  uploadedAt        DateTime                              @default(now())
  createdAt         DateTime                              @default(now())
  updatedAt         DateTime                              @updatedAt

  @@index([archiveCategoryId, uploadedAt])
  @@index([uploadedById])
  @@index([status])
}

model ManualLibraryAsset {
  id               String                            @id @default(cuid())
  assetName        String
  originalFileName String
  createdByName    String?
  description      String?
  category         String?
  mimeType         String
  fileSize         Int
  bucket           String
  storageKey       String                            @unique
  status           AttachmentStatus                  @default(UPLOADING)
  uploadedById     String
  uploadedBy       User                              @relation("ManualLibraryAssetUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)
  assetTags        ManualLibraryAssetTagAssignment[]
  manualLibraryAssetFavorites ManualLibraryAssetFavorite[]
  uploadedAt       DateTime                          @default(now())
  createdAt        DateTime                          @default(now())
  updatedAt        DateTime                          @updatedAt

  @@index([category, uploadedAt])
  @@index([uploadedById])
  @@index([status])
}

model Notification {
  id           String                  @id @default(cuid())
  userId       String
  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         NotificationType
  title        String
  message      String
  entityType   NotificationEntityType?
  entityId     String?
  projectId    String?
  stageId      String?
  revisionId   String?
  commentId    String?
  attachmentId String?
  archiveId    String?
  url          String?
  isRead       Boolean                 @default(false)
  readAt       DateTime?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@index([userId, createdAt])
  @@index([userId, isRead, createdAt])
  @@index([projectId, createdAt])
  @@index([type, createdAt])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model CalendarEvent {
  id          String            @id @default(cuid())
  title       String
  details     String?
  startAt     DateTime
  endAt       DateTime
  type        CalendarEventType
  tone        CalendarEventTone
  createdById String
  createdBy   User              @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([startAt])
  @@index([endAt])
  @@index([createdById])
}
