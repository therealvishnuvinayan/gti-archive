generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  COLLABORATOR
}

enum ProjectStatus {
  ONGOING
  ON_HOLD
  PENDING
  COMPLETED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  role         UserRole  @default(COLLABORATOR)
  sessions     Session[]
  projects     Project[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Project {
  id               String        @id @default(cuid())
  name             String
  category         String
  tag              String?
  description      String
  budget           Int
  status           ProjectStatus @default(ONGOING)
  startDate        DateTime
  endDate          DateTime
  currentStageName String?
  stageCount       Int           @default(1)
  createdById      String
  createdBy        User          @relation(fields: [createdById], references: [id], onDelete: Restrict)
  stages           ProjectStage[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([createdById])
}

model ProjectStage {
  id        String        @id @default(cuid())
  projectId String
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  budget    Int?
  status    ProjectStatus @default(PENDING)
  order     Int
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([projectId, order])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}
